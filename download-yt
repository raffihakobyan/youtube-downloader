#!/usr/bin/env bash
#
# download-yt — простой CLI для скачивания видео/аудио с YouTube.
#
#   download-yt <URL> 720     # видео до 720p  (mp4)
#   download-yt <URL> 1080    # видео до 1080p (mp4)
#   download-yt <URL> mp3     # аудио в mp3, максимальное качество
#
# Требуется: yt-dlp, ffmpeg (устанавливаются через install.sh).

set -euo pipefail

VERSION="1.0.0"

# --- Каталог для сохранения --------------------------------------------------
# По умолчанию — текущая папка терминала (PWD).
# Можно переопределить: DOWNLOAD_YT_DIR=/path download-yt ...
OUT_DIR="${DOWNLOAD_YT_DIR:-$PWD}"

# --- Цвета для вывода --------------------------------------------------------
if [[ -t 1 ]]; then
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'
  C_BOLD=$'\033[1m'; C_RESET=$'\033[0m'
else
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BOLD=""; C_RESET=""
fi

msg()  { printf '%s\n' "$*"; }
info() { printf '%s➜%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf '%s⚠%s  %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()  { printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }

usage() {
  cat <<EOF
${C_BOLD}download-yt${C_RESET} v${VERSION} — скачивание видео/аудио с YouTube

${C_BOLD}Использование:${C_RESET}
  download-yt <URL> [качество]

${C_BOLD}Качество:${C_RESET} (необязательно, по умолчанию 1080)
  144 | 240 | 360 | 480 | 720 | 1080 | 1440 | 2160   видео (mp4) до указанной высоты
  mp3                                                 аудио в mp3 (максимальное качество)

${C_BOLD}Примеры:${C_RESET}
  download-yt "https://www.youtube.com/watch?v=vZqvVhcHsZM"        # 1080p по умолчанию
  download-yt "https://www.youtube.com/watch?v=vZqvVhcHsZM" 720
  download-yt "https://www.youtube.com/watch?v=vZqvVhcHsZM" mp3

  ${C_YELLOW}Важно:${C_RESET} берите ссылку в кавычки — иначе zsh воспримет ? и & как шаблон
         и выдаст «zsh: no matches found».

${C_BOLD}Опции:${C_RESET}
  -h, --help       показать эту справку
  -v, --version    показать версию

${C_BOLD}Куда сохраняется:${C_RESET}
  По умолчанию — в текущую папку терминала.
  Переопределить: DOWNLOAD_YT_DIR=/path download-yt <URL>
EOF
}

# --- Разбор аргументов -------------------------------------------------------
case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  -v|--version) msg "download-yt v${VERSION}"; exit 0 ;;
  "") err "Не указан URL."; msg; usage; exit 1 ;;
esac

URL="$1"
# Качество не указано → по умолчанию 1080p.
QUALITY="${2:-1080}"

# --- Проверка зависимостей ---------------------------------------------------
if ! command -v yt-dlp >/dev/null 2>&1; then
  err "yt-dlp не найден. Запустите install.sh или: brew install yt-dlp"
  exit 127
fi
if ! command -v ffmpeg >/dev/null 2>&1; then
  err "ffmpeg не найден. Запустите install.sh или: brew install ffmpeg"
  exit 127
fi

mkdir -p "$OUT_DIR"

OUTPUT_TMPL="$OUT_DIR/%(title)s [%(id)s].%(ext)s"

# --- Формируем аргументы yt-dlp по режиму ------------------------------------
QUALITY_LC="$(printf '%s' "$QUALITY" | tr '[:upper:]' '[:lower:]')"

# Общие опции + встроенные повторы (помогают при обрывах/тайм-аутах).
COMMON_ARGS=(
  --no-playlist
  --embed-metadata
  --retries 10
  --fragment-retries 10
  --extractor-retries 5
  -o "$OUTPUT_TMPL"
)

if [[ "$QUALITY_LC" == "mp3" ]]; then
  info "Скачиваю аудио в mp3 (максимальное качество) → $OUT_DIR"
  # -x               извлечь аудио
  # --audio-format   привести к mp3 (конвертация на ffmpeg, если mp3-дорожки нет)
  # --audio-quality 0  наилучшее качество (VBR ~245 kbps)
  MODE_ARGS=( -x --audio-format mp3 --audio-quality 0 --embed-thumbnail )

elif [[ "$QUALITY_LC" =~ ^[0-9]+$ ]]; then
  HEIGHT="$QUALITY_LC"
  info "Скачиваю видео до ${HEIGHT}p (mp4) → $OUT_DIR"
  # Берём лучшее видео с высотой <= HEIGHT + лучшее аудио, склеиваем в mp4.
  MODE_ARGS=( -f "bv*[height<=${HEIGHT}]+ba/b[height<=${HEIGHT}]/bv*+ba/b" --merge-output-format mp4 )

else
  err "Неизвестное качество: «$QUALITY». Используйте число (720, 1080…) или mp3."
  msg; usage; exit 1
fi

# --- Запуск с повтором при «плавающем» HTTP 403 ------------------------------
# YouTube иногда отдаёт ссылки на поток, которые затем возвращают 403.
# Повторный запуск заново извлекает свежие ссылки и обычно решает проблему.
MAX_TRIES=3
attempt=1
while (( attempt <= MAX_TRIES )); do
  if yt-dlp "${MODE_ARGS[@]}" "${COMMON_ARGS[@]}" "$URL"; then
    exit 0
  fi
  status=$?
  if (( attempt < MAX_TRIES )); then
    warn "Попытка $attempt не удалась (возможно, HTTP 403). Повтор со свежими ссылками…"
    sleep 2
  fi
  (( attempt++ ))
done

err "Не удалось скачать после ${MAX_TRIES} попыток."
err "Попробуйте обновить yt-dlp:  brew upgrade yt-dlp"
exit "${status:-1}"
