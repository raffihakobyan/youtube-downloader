#!/usr/bin/env bash
#
# download-yt — простой CLI для скачивания видео/аудио с YouTube.
#
#   download-yt <URL> 720     # видео до 720p  (mp4)
#   download-yt <URL> 1080    # видео до 1080p (mp4)
#   download-yt <URL> mp3     # аудио в mp3, максимальное качество
#
# Требуется: yt-dlp, ffmpeg (устанавливаются через install.sh).

set -euo pipefail

VERSION="1.0.0"

# --- Каталог для сохранения --------------------------------------------------
# По умолчанию ~/Downloads, можно переопределить: DOWNLOAD_YT_DIR=/path download-yt ...
OUT_DIR="${DOWNLOAD_YT_DIR:-$HOME/Downloads}"

# --- Цвета для вывода --------------------------------------------------------
if [[ -t 1 ]]; then
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'
  C_BOLD=$'\033[1m'; C_RESET=$'\033[0m'
else
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BOLD=""; C_RESET=""
fi

msg()  { printf '%s\n' "$*"; }
info() { printf '%s➜%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf '%s⚠%s  %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()  { printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }

usage() {
  cat <<EOF
${C_BOLD}download-yt${C_RESET} v${VERSION} — скачивание видео/аудио с YouTube

${C_BOLD}Использование:${C_RESET}
  download-yt <URL> <качество>

${C_BOLD}Качество:${C_RESET}
  144 | 240 | 360 | 480 | 720 | 1080 | 1440 | 2160   видео (mp4) до указанной высоты
  mp3                                                 аудио в mp3 (максимальное качество)

${C_BOLD}Примеры:${C_RESET}
  download-yt https://www.youtube.com/watch?v=vZqvVhcHsZM 720
  download-yt https://www.youtube.com/watch?v=vZqvVhcHsZM 1080
  download-yt https://www.youtube.com/watch?v=vZqvVhcHsZM mp3

${C_BOLD}Опции:${C_RESET}
  -h, --help       показать эту справку
  -v, --version    показать версию

${C_BOLD}Переменные окружения:${C_RESET}
  DOWNLOAD_YT_DIR  каталог для сохранения (по умолчанию ~/Downloads)
EOF
}

# --- Разбор аргументов -------------------------------------------------------
case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  -v|--version) msg "download-yt v${VERSION}"; exit 0 ;;
  "") err "Не указан URL."; msg; usage; exit 1 ;;
esac

URL="$1"
QUALITY="${2:-}"

if [[ -z "$QUALITY" ]]; then
  err "Не указано качество (720 / 1080 / mp3 и т.п.)."
  msg; usage; exit 1
fi

# --- Проверка зависимостей ---------------------------------------------------
if ! command -v yt-dlp >/dev/null 2>&1; then
  err "yt-dlp не найден. Запустите install.sh или: brew install yt-dlp"
  exit 127
fi
if ! command -v ffmpeg >/dev/null 2>&1; then
  err "ffmpeg не найден. Запустите install.sh или: brew install ffmpeg"
  exit 127
fi

mkdir -p "$OUT_DIR"

OUTPUT_TMPL="$OUT_DIR/%(title)s [%(id)s].%(ext)s"

# --- Скачивание --------------------------------------------------------------
QUALITY_LC="$(printf '%s' "$QUALITY" | tr '[:upper:]' '[:lower:]')"

if [[ "$QUALITY_LC" == "mp3" ]]; then
  info "Скачиваю аудио в mp3 (максимальное качество) → $OUT_DIR"
  # -x               извлечь аудио
  # --audio-format   привести к mp3 (конвертация на ffmpeg, если mp3-дорожки нет)
  # --audio-quality 0  наилучшее качество (VBR ~245 kbps)
  exec yt-dlp \
    -x \
    --audio-format mp3 \
    --audio-quality 0 \
    --embed-thumbnail \
    --embed-metadata \
    --no-playlist \
    -o "$OUTPUT_TMPL" \
    "$URL"

elif [[ "$QUALITY_LC" =~ ^[0-9]+$ ]]; then
  HEIGHT="$QUALITY_LC"
  info "Скачиваю видео до ${HEIGHT}p (mp4) → $OUT_DIR"
  # Берём лучшее видео с высотой <= HEIGHT + лучшее аудио, склеиваем в mp4.
  exec yt-dlp \
    -f "bv*[height<=${HEIGHT}]+ba/b[height<=${HEIGHT}]/bv*+ba/b" \
    --merge-output-format mp4 \
    --embed-metadata \
    --no-playlist \
    -o "$OUTPUT_TMPL" \
    "$URL"

else
  err "Неизвестное качество: «$QUALITY». Используйте число (720, 1080…) или mp3."
  msg; usage; exit 1
fi
